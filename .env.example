JWT_SECRET=

CRYPTOBOT_TOKEN=

# Telegram Login (get from @BotFather → Bot Settings → Web Login)
TG_BOT_TOKEN=
# OIDC: Client ID and Secret from BotFather (Bot Settings → Web Login)
TG_CLIENT_ID=
TG_CLIENT_SECRET=
# Frontend: Telegram Bot Client ID (numeric Bot ID, same as TG_CLIENT_ID)
VITE_TG_CLIENT_ID=

# Admin: Telegram user ID that will be auto-promoted to admin
ADMIN_TELEGRAM_ID=
ADMIN_USERNAME=admin

SERVER_IP=
SERVER_PORT=3000
BASE_URL=https://staytg.org

# PostgreSQL DSN
DATABASE_URL=postgres://mtproxy:yourpassword@localhost:5432/mtproxy?sslmode=disable

PORT_MIN=8000
PORT_MAX=9999
SOCKS5_PORT_MIN=10000
SOCKS5_PORT_MAX=10999
DEFAULT_MAX_PROXIES=5

MTG_IMAGE=nineseconds/mtg:2
GOST_IMAGE=ginuerzh/gost:2.12

# x-ui / 3x-ui panel integration for VLESS VPN links (optional)
# Leave XUI_URL empty to disable VLESS support
XUI_URL=https://muftifan.ru
XUI_PATH_PREFIX=vwtLfHqxkCntctQ   # custom panel base path (Security → Panel Settings → Panel Base Path)
XUI_USERNAME=admin
XUI_PASSWORD=your-xui-password
XUI_INBOUND_ID=1
